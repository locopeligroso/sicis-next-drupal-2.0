# ============================================================
# Sicis Next.js — Local Environment Example
# Copia questo file in .env.local e aggiorna i valori
# ============================================================

# Drupal URL server-side (Drupal su LAN)
DRUPAL_BASE_URL=http://192.168.86.201/www.sicis.com_aiweb/httpdocs

# Drupal URL pubblico (usato nel browser per immagini/asset)
NEXT_PUBLIC_DRUPAL_BASE_URL=http://192.168.86.201/www.sicis.com_aiweb/httpdocs

# ISR revalidation secret (deve corrispondere a REVALIDATE_SECRET in Drupal)
REVALIDATE_SECRET=your_secret_here
