# Drupal Configuration
# Backend headless Drupal CMS base URL (server-side only)
DRUPAL_BASE_URL=https://cms.example.com

# Drupal Configuration (publicly visible via next/image optimization)
# Must be accessible from browser for image loading
NEXT_PUBLIC_DRUPAL_BASE_URL=https://cms.example.com

# Revalidation Secret
# Used to authenticate on-demand revalidation requests via /api/revalidate?secret=...
# Minimum 8 characters. Generate with: openssl rand -base64 12
REVALIDATE_SECRET=your-secure-secret-key-here
